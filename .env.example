# Root .env.example — used by docker-compose (`env_file: .env` in docker-compose.yml).
# Copy to `.env` in this directory and fill in values before:
#   docker compose up --build
#   # or: docker-compose up --build
#
# Then open http://localhost:3000 (frontend) and http://localhost:8000/docs (API).

OPENROUTER_API_KEY=your_key_here
BYPASS_CACHE=false
DATABASE_URL=sqlite:///./freightmind.db
CACHE_DIR=./cache
LLM_MAX_TOKENS=2048

# Inference providers — "ollama" (local) or "openrouter" (cloud)
ANALYTICS_PROVIDER=ollama
VISION_PROVIDER=openrouter
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Analytics model: any model pulled in Ollama (ollama pull llama3.1:8b)
ANALYTICS_MODEL=llama3.1:8b
ANALYTICS_MODEL_FALLBACK=llama3.2:3b
# Vision model: OpenRouter model id (required when VISION_PROVIDER=openrouter)
VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
VISION_MODEL_FALLBACK=qwen/qwen2.5-vl-7b-instruct:free

# Optional
# CORS_ORIGINS=*
# MAX_UPLOAD_BYTES=10485760

# Live seeding — drip one random synthetic row at this interval (seconds). 0 = off.
# LIVE_SEEDING_INTERVAL_SECONDS=0
