# Root .env.example — used by docker-compose (`env_file: .env` in docker-compose.yml).
# Copy to `.env` in this directory and fill in values before:
#   docker compose up --build
#   # or: docker-compose up --build
#
# Then open http://localhost:3000 (frontend) and http://localhost:8000/docs (API).

OPENROUTER_API_KEY=your_key_here
BYPASS_CACHE=false
DATABASE_URL=sqlite:///./freightmind.db
CACHE_DIR=./cache

# Optional — backend defaults apply if unset (see backend/.env.example)
# CORS_ORIGINS=*
# MAX_UPLOAD_BYTES=10485760
# LLM_MAX_TOKENS=8192

# Live seeding — drip synthetic rows into shipments at this interval (seconds).
# 0 = disabled. Set to 30 for demo live-data effect (numbers tick up every 30s).
# LIVE_SEEDING_INTERVAL_SECONDS=0
