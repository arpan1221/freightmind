# Backend environment (local `uv run` from ./backend).
#
# For Docker Compose, use the repo-root `.env.example` / `.env` instead — compose loads
# that file into the backend container (see root `docker-compose.yml`).

# Required only when ANALYTICS_PROVIDER or VISION_PROVIDER is "openrouter"
OPENROUTER_API_KEY=your_key_here

# Inference provider per agent: "openrouter" | "ollama" (default: analytics=ollama, vision=openrouter)
ANALYTICS_PROVIDER=ollama
VISION_PROVIDER=openrouter

# Ollama endpoint — use host.docker.internal when running inside Docker, localhost otherwise
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# Render sets PORT automatically — do not set locally unless you override the container listen port.

# Optional — defaults shown
BYPASS_CACHE=false
DATABASE_URL=sqlite:///./freightmind.db
CACHE_DIR=./cache

# CORS: "*" for local dev; production use comma-separated UI origins (e.g. https://app.vercel.app)
# CORS_ORIGINS=*

# Max upload size for POST /api/documents/extract (bytes). Default 10 MiB.
# MAX_UPLOAD_BYTES=10485760

# Max completion tokens per LLM call (OpenRouter max_tokens). Lower if you see HTTP 402.
# LLM_MAX_TOKENS=8192

# Model ids — Ollama format (e.g. llama3.2:3b) or OpenRouter format (e.g. meta-llama/llama-3.3-70b-instruct)
# ANALYTICS_MODEL=llama3.2:3b
# ANALYTICS_MODEL_FALLBACK=llama3.2:3b
# VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
# VISION_MODEL_FALLBACK=qwen/qwen2.5-vl-7b-instruct:free
